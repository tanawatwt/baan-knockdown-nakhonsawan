---
import { site } from '~/data/site';

const primaryNav = [
  { href: '/services', label: 'บริการ' },
  { href: '/models', label: 'แบบบ้าน / ราคา' },
  { href: '/portfolio', label: 'ผลงาน' },
  { href: '/blog', label: 'บทความ' },
];

const moreNav = [
  { href: '/process', label: 'ขั้นตอนการทำงาน' },
  { href: '/about', label: 'เกี่ยวกับเรา' },
  { href: '/faq', label: 'คำถามที่พบบ่อย' },
  { href: '/promotions', label: 'โปรโมชั่น' },
];

const rawPath = Astro.url.pathname;
const currentPath = rawPath === '/' ? '/' : rawPath.replace(/\/$/, '');
const isMoreActive = moreNav.some((i) => i.href === currentPath);
---

<div class="top-bar">
  <div class="container">
    <div class="left">
      <a href={`tel:${site.phonesE164[0]}`}>
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {site.phones[0]}
      </a>
      <a href={site.lineUrl} target="_blank" rel="noopener">LINE: {site.lineId}</a>
    </div>
    <div class="right">
      <span>เปิดทุกวัน 08:00–17:00 น.</span>
    </div>
  </div>
</div>

<header class="site">
  <div class="container">
    <div class="nav">
      <a href="/" class="brand" aria-label={site.name}>
        <img src="/logo-header.png" alt={site.name} width="160" height="68" />
        <div class="brand-text">
          <strong>เรื่องบ้านบ้านน็อคดาวน์</strong>
          <span>นครสวรรค์ • รับสร้างบ้านน็อคดาวน์ครบวงจร</span>
        </div>
      </a>
      <nav class="nav-links" id="nav-links" aria-label="หลัก">
        <a href="/" class={currentPath === '/' ? 'active' : undefined} aria-current={currentPath === '/' ? 'page' : undefined}>หน้าแรก</a>
        {primaryNav.map((item) => (
          <a
            href={item.href}
            class={currentPath === item.href ? 'active' : undefined}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >{item.label}</a>
        ))}
        <details class={`nav-more${isMoreActive ? ' active' : ''}`}>
          <summary>เพิ่มเติม</summary>
          <div class="nav-more-menu">
            {moreNav.map((item) => (
              <a
                href={item.href}
                class={currentPath === item.href ? 'active' : undefined}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >{item.label}</a>
            ))}
          </div>
        </details>
      </nav>
      <div class="nav-cta">
        <a href={`tel:${site.phonesE164[0]}`} class="btn btn-ghost">โทรเลย</a>
        <a href="/contact" class="btn btn-primary">ขอใบเสนอราคา</a>
      </div>
      <button class="hamburger" aria-label="เปิดเมนู" aria-expanded="false" aria-controls="nav-links">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.hamburger');
  const nav = document.querySelector<HTMLElement>('.nav-links');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('open', !expanded);
  });

  // Close the "เพิ่มเติม" dropdown when clicking outside (desktop only)
  document.addEventListener('click', (e) => {
    const more = document.querySelector<HTMLDetailsElement>('.nav-more');
    if (!more) return;
    if (!more.contains(e.target as Node)) more.open = false;
  });
</script>
