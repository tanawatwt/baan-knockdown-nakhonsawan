---
import { site } from '~/data/site';

interface Props { headline?: string; sub?: string }
const {
  headline = 'สนใจสร้างบ้านน็อคดาวน์ ปรึกษาฟรีวันนี้',
  sub = 'ส่งแบบหรือพื้นที่หน้างานมาให้ทีมงานประเมินราคาเบื้องต้นได้เลย ไม่มีค่าใช้จ่าย',
} = Astro.props;
---
<section>
  <div class="container">
    <div class="fcta">
      <h2>{headline}</h2>
      <p>{sub}</p>
      <div class="fcta-btns">
        <a href={`tel:${site.phonesE164[0]}`} class="btn btn-yellow btn-lg">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="18" height="18">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          โทรเลย {site.phones[0]}
        </a>
        <a href={site.lineUrl} class="btn btn-light btn-lg" rel="noopener" target="_blank">
          แอด LINE {site.lineId}
        </a>
        <a href="/contact" class="btn btn-light btn-lg">ขอใบเสนอราคา</a>
      </div>
    </div>
  </div>
</section>
