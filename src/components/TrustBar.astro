---
import { site } from '~/data/site';
---
<div class="trust">
  <div class="container trust-grid">
    <div class="item">
      <div class="ico">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div><strong>สร้างไว 15–45 วัน</strong><span>เสร็จเร็วกว่าก่ออิฐ</span></div>
    </div>
    <div class="item">
      <div class="ico">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div><strong>ราคาคุ้มค่า</strong><span>เริ่มต้น ฿{site.startingPriceTHB.toLocaleString()} บาท</span></div>
    </div>
    <div class="item">
      <div class="ico">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3 6 6 .9-4.5 4.4 1 6.7L12 17l-5.5 3 1-6.7L3 8.9l6-.9z"/></svg>
      </div>
      <div><strong>ปรับแบบได้</strong><span>ตามงบและพื้นที่จริง</span></div>
    </div>
    <div class="item">
      <div class="ico">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2z" transform="translate(0,-1)"/></svg>
      </div>
      <div><strong>ครบจบในที่เดียว</strong><span>ออกแบบ ผลิต ติดตั้ง</span></div>
    </div>
  </div>
</div>
