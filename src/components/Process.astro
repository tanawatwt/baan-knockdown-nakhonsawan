---
const steps = [
  { n: 1, title: 'ติดต่อสอบถาม', desc: 'ส่งรายละเอียด งบประมาณ หรือแบบที่สนใจ' },
  { n: 2, title: 'ประเมินหน้างาน', desc: 'ทีมงานประเมินพื้นที่ สรุปแบบและความต้องการ' },
  { n: 3, title: 'ตกลงราคา / มัดจำ', desc: 'ยืนยันแบบ ราคา และเงื่อนไขการทำงาน' },
  { n: 4, title: 'ผลิตโครงสร้าง', desc: 'ผลิตตามแบบและวัสดุที่ตกลงในโรงงาน' },
  { n: 5, title: 'ติดตั้งหน้างาน', desc: 'ทีมงานเข้าติดตั้งตามกำหนด ควบคุมคุณภาพ' },
  { n: 6, title: 'ส่งมอบงาน', desc: 'ตรวจสอบงานและส่งมอบให้ลูกค้า' },
];
---
<div class="steps">
  {steps.map((s) => (
    <div class="step">
      <div class="stepnum">{s.n}</div>
      <h4>{s.title}</h4>
      <p>{s.desc}</p>
    </div>
  ))}
</div>
