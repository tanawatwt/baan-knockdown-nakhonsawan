{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "baan-knockdown-nakhonsawan",
  "compatibility_date": "2026-05-01",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "banbanknockdown.com", "custom_domain": true },
    { "pattern": "www.banbanknockdown.com", "custom_domain": true }
  ]
}
